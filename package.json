{
    "name": "boilerplate-wordpress",
    "version": "2.0.0",
    "description": "WordPress boilerplate — Vite + Tailwind CSS v4 + GSAP",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "legacy:dev": "cross-env NODE_ENV=development webpack --watch --mode development --progress",
        "legacy:build": "cross-env NODE_ENV=production webpack --mode production --progress",
        "clean": "rm -rf build/*"
    },
    "keywords": [
        "wordpress",
        "themes"
    ],
    "author": "Imran Sayed",
    "license": "MIT",
    "private": true,
    "engines": {
        "node": ">=18.0.0"
    },
    "devDependencies": {
        "@babel/core": "^7.23.0",
        "@babel/preset-env": "^7.23.0",
        "@tailwindcss/vite": "^4.3.0",
        "babel-loader": "^9.1.3",
        "browser-sync-webpack-plugin": "^2.3.0",
        "cross-env": "^7.0.3",
        "css-loader": "^6.8.1",
        "css-minimizer-webpack-plugin": "^5.0.1",
        "cssnano": "^6.0.1",
        "mini-css-extract-plugin": "^2.7.6",
        "postcss": "^8.4.31",
        "postcss-loader": "^7.3.3",
        "sass": "^1.69.5",
        "sass-loader": "^13.3.2",
        "style-loader": "^3.3.3",
        "tailwindcss": "^4.3.0",
        "terser-webpack-plugin": "^5.3.9",
        "vite": "^8.0.11",
        "vite-plugin-full-reload": "^1.2.0",
        "webpack": "^5.89.0",
        "webpack-cli": "^5.1.4"
    },
    "browserslist": [
        "defaults"
    ],
    "dependencies": {
        "browser-sync": "^2.29.3",
        "gsap": "^3.15.0",
        "swiper": "^12.1.4"
    }
}
